---
const home = import.meta.env.BASE_URL;
---
<nav>
  <a href={home} class="site-name">lakshay saini</a>
  <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="nav-links">menu</button>
  <div class="nav-links" id="nav-links">
    <a href={`${home}#research`}>research</a>
    <span class="sep">/</span>
    <a href={`${home}#projects`}>projects</a>
    <span class="sep">/</span>
    <a href={`${home}#experience`}>experience</a>
    <span class="sep">/</span>
    <a href={`${home}#contact`}>contact</a>
    <span class="sep">/</span>
    <button class="theme-toggle" type="button" aria-pressed="false">dark</button>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 52px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    z-index: 1000;
  }
  .site-name {
    font-weight: 600;
    text-decoration: none;
    text-transform: lowercase;
  }
  .nav-links {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .nav-links a,
  .theme-toggle {
    text-decoration: none;
    font-size: var(--size-sm);
    font-family: var(--font);
    background: none;
    border: none;
    color: inherit;
    padding: 0;
    cursor: pointer;
    text-transform: lowercase;
  }
  .nav-links a:hover,
  .theme-toggle:hover {
    opacity: 0.6;
    transition: opacity 120ms linear;
  }
  .sep {
    color: var(--dim);
  }
  .mobile-menu-toggle {
    display: none;
    background: none;
    border: 1px solid var(--border);
    color: var(--fg);
    font-family: var(--font);
    font-size: var(--size-sm);
    text-transform: lowercase;
    padding: 4px 10px;
    cursor: pointer;
  }
  .mobile-menu-toggle:hover {
    opacity: 0.6;
  }

  @media (max-width: 600px) {
    .mobile-menu-toggle {
      display: block;
    }
    .nav-links {
      display: none;
      position: fixed;
      top: 52px;
      left: 0;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
    }
    .nav-links.open {
      display: flex;
    }
    .nav-links a,
    .theme-toggle {
      display: block;
      width: 100%;
      text-align: left;
      padding: 14px 24px;
      border-top: 1px solid var(--border);
    }
    .sep {
      display: none;
    }
  }
</style>

<script>
  const menuToggle = document.querySelector<HTMLButtonElement>('.mobile-menu-toggle');
  const links = document.querySelector<HTMLDivElement>('.nav-links');

  const closeMenu = () => {
    links?.classList.remove('open');
    menuToggle?.setAttribute('aria-expanded', 'false');
    if (menuToggle) menuToggle.textContent = 'menu';
  };

  menuToggle?.addEventListener('click', () => {
    const isOpen = links?.classList.toggle('open') ?? false;
    menuToggle.setAttribute('aria-expanded', String(isOpen));
    menuToggle.textContent = isOpen ? 'close' : 'menu';
  });

  links?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  const THEME_KEY = 'theme';
  const root = document.documentElement;
  const themeToggle = document.querySelector<HTMLButtonElement>('.theme-toggle');

  const syncThemeToggle = () => {
    const isDark = root.dataset.theme === 'dark';
    if (!themeToggle) return;
    themeToggle.textContent = isDark ? 'light' : 'dark';
    themeToggle.setAttribute('aria-pressed', String(isDark));
  };

  syncThemeToggle();

  themeToggle?.addEventListener('click', () => {
    const goingDark = root.dataset.theme !== 'dark';
    if (goingDark) {
      root.dataset.theme = 'dark';
    } else {
      delete root.dataset.theme;
    }
    localStorage.setItem(THEME_KEY, goingDark ? 'dark' : 'light');
    syncThemeToggle();
  });
</script>
