---
---
<nav>
  <a href="./" class="site-name">lakshay saini</a>
  <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="nav-links">menu</button>
  <div class="nav-links" id="nav-links">
    <a href="./#research">research</a>
    <span class="sep">/</span>
    <a href="./#projects">projects</a>
    <span class="sep">/</span>
    <a href="./#experience">experience</a>
    <span class="sep">/</span>
    <a href="./#contact">contact</a>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 52px;
    background: var(--black);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    z-index: 1000;
  }
  .site-name {
    font-weight: 600;
    text-decoration: none;
    text-transform: lowercase;
  }
  .nav-links {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .nav-links a {
    text-decoration: none;
    font-size: var(--size-sm);
  }
  .nav-links a:hover {
    opacity: 0.6;
    transition: opacity 120ms linear;
  }
  .sep {
    color: var(--dim);
  }
  .mobile-menu-toggle {
    display: none;
    background: none;
    border: 1px solid var(--border);
    color: var(--white);
    font-family: var(--font);
    font-size: var(--size-sm);
    text-transform: lowercase;
    padding: 4px 10px;
    cursor: pointer;
  }
  .mobile-menu-toggle:hover {
    opacity: 0.6;
  }

  @media (max-width: 600px) {
    .mobile-menu-toggle {
      display: block;
    }
    .nav-links {
      display: none;
      position: fixed;
      top: 52px;
      left: 0;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--black);
      border-bottom: 1px solid var(--border);
    }
    .nav-links.open {
      display: flex;
    }
    .nav-links a {
      padding: 14px 24px;
      border-top: 1px solid var(--border);
    }
    .sep {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.mobile-menu-toggle');
  const links = document.querySelector<HTMLDivElement>('.nav-links');

  const closeMenu = () => {
    links?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    if (toggle) toggle.textContent = 'menu';
  };

  toggle?.addEventListener('click', () => {
    const isOpen = links?.classList.toggle('open') ?? false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.textContent = isOpen ? 'close' : 'menu';
  });

  links?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
