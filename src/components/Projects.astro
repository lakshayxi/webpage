---
import ProjectCard from './ProjectCard.astro';
---
<section id="projects">
  <hr class="section-rule" />
  <p class="label">02 — projects</p>
  <h2>Things I built</h2>

  <div class="project-list">
    <ProjectCard
      name="CacheVista"
      year="Mar 2026"
      tags="PyTorch, CLIP, FAISS, Python"
      desc="A cache that stops vision-language models from doing the same expensive work twice. When the same or a very similar image shows up again, CacheVista reuses what it already computed instead of re-encoding it from scratch — cutting compute with no loss in accuracy."
      slug="cachevista"
      github="https://github.com/lakshayxi/CacheVista"
    />
    <ProjectCard
      name="SMLM"
      year="Mar 2026"
      tags="PyTorch, ViT, Transformer, Python"
      desc="A vision-language model I built entirely from scratch, just to understand how these systems actually learn to connect images and text. Training two different sizes of it taught me more about what makes small models fail than any paper did."
      slug="smlm"
      github="https://github.com/lakshayxi/SMLM"
    />
    <ProjectCard
      name="Glimpse"
      year="May 2026"
      tags="PyTorch, CLIP, LoRA, Python"
      desc="I tested eight different ways of combining image and text understanding to answer questions about pictures — and the simplest one won. A method that just reuses signals CLIP already computes beat every more complicated architecture I tried."
      slug="glimpse"
      github="https://github.com/lakshayxi/glimpse"
    />
    <ProjectCard
      name="Maya"
      year="Mar 2026"
      tags="PyTorch, NLP, Python"
      desc="A next-word prediction model for Hindi, a language English-first NLP tools tend to handle poorly. Comparing several architectures showed that a simple model can beat more complex ones when the training data is small."
      slug="maya"
      github="https://github.com/lakshayxi/maya"
    />
    <ProjectCard
      name="PaperScope"
      year="Apr 2026"
      tags="Python, OpenReview API, Claude Code"
      desc="A tool that tells you how to actually read a peer review score. It pulls real review data from 35 ML conferences to show whether a given venue's reviewers tend to score generously or harshly, so a 6/10 means something concrete instead of just a number."
      slug="paperscope"
      github="https://github.com/lakshayxi/PaperScope"
    />
    <div class="bottom-border"></div>
  </div>
</section>

<style>
  h2 {
    font-size: var(--size-xl);
    font-weight: 600;
    margin: 12px 0 48px 0;
  }
  .bottom-border {
    border-top: 1px solid var(--border);
  }
</style>